# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key (required for AI analysis in bridge.py)
ANTHROPIC_API_KEY=your_key_here

# Path to the compiled C++ engine binary
ENGINE_PATH=./engine/engine

# Log file directory to monitor
LOG_DIR=./logs/samples

# Threat sensitivity level: low | medium | high
THREAT_LEVEL=medium
